# BioAnalytics Pro — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores

# ── Aplicação ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development          # development | staging | production

# ── Autenticação (futura integração) ──────────────────────────────────────────
# AUTH_SECRET=                           # openssl rand -base64 32
# AUTH_URL=http://localhost:3000

# ── Banco de dados (futura integração) ────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/bioanalytics

# ── Serviços externos (futura integração) ─────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Observabilidade ───────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
