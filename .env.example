# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # anon / public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # service_role key — NUNCA expor no frontend

# ─── Aplicação ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://bioanalytics.pro

# ─── Auditoria interna ────────────────────────────────────────────────────────
# Segredo compartilhado para o endpoint POST /api/audit/logs
# Gere com: openssl rand -hex 32
AUDIT_SECRET=

# ─── WhatsApp Business API ────────────────────────────────────────────────────
# Documentação: https://developers.facebook.com/docs/whatsapp/cloud-api
# Acesse: https://developers.facebook.com/apps → seu app → WhatsApp → Configuração da API

# Token de acesso permanente (System User com permissão whatsapp_business_messaging)
WHATSAPP_TOKEN=

# Phone Number ID (não é o número de telefone, mas o ID numérico da plataforma)
WHATSAPP_PHONE_ID=

# Token de verificação do webhook (você define, qualquer string aleatória)
WHATSAPP_VERIFY_TOKEN=

# App Secret para validação HMAC-SHA256 do webhook
# Acesse: Configurações do App → Básico → App Secret
WHATSAPP_APP_SECRET=

# ─── Autenticação (produção) ──────────────────────────────────────────────────
# Substitua o cookie de demonstração por NextAuth ou Supabase Auth em produção
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://bioanalytics.pro
